{
  "name": "hbar-agentic-harness",
  "version": "0.1.0",
  "description": "Agentic harness for validating scaffold-hbar templates.",
  "type": "module",
  "bin": {
    "hbar-harness": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "harness": "npm run build --silent && node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
