{
  "$schema": "./static-validator.schema.json",
  "name": "blind-hedera-demo-static",
  "description": "Minimal static invariants for blind Hedera demo template generation.",
  "jsonAssertions": [
    {
      "file": "template.json",
      "path": "name",
      "equals": "proof-wall-demo"
    },
    {
      "file": "template.json",
      "path": "create-scaffold-hbar.capabilities.frontend",
      "equals": ["nextjs-app"]
    },
    {
      "file": "template.json",
      "path": "create-scaffold-hbar.capabilities.solidityFramework",
      "equals": ["none"]
    },
    {
      "file": "package.json",
      "path": "workspaces.packages",
      "equals": ["packages/nextjs"]
    },
    {
      "file": "package.json",
      "path": "packageManager",
      "equals": "yarn@3.2.3"
    }
  ],
  "fileAssertions": {
    "required": [
      "template.json",
      "README.md",
      "AGENTS.md",
      "package.json",
      "packages/nextjs/package.json"
    ],
    "forbidden": [
      ".env",
      "packages/hardhat",
      "packages/foundry"
    ]
  },
  "textAssertions": [
    {
      "file": "README.md",
      "contains": ["yarn install", "yarn next:dev"]
    },
    {
      "file": "AGENTS.md",
      "contains": ["yarn next:dev"]
    }
  ]
}
